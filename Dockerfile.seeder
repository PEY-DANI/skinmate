FROM python:3.12-slim

WORKDIR /app

# setuptools packages.find(where=["src"])가 src/ 존재를 요구하므로, pip install 전에
# 소스코드부터 복사해야 한다(pyproject.toml만 먼저 복사하면 빌드가 실패함).
COPY pyproject.toml /app/
COPY src/ /app/src/
COPY scripts/ /app/scripts/
RUN pip install --no-cache-dir .

# 실행 명령
CMD ["python", "scripts/populate_graph.py"]
